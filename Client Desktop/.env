# ============ CONFIGURATION API ============
# URL de base du serveur API
API_BASE_URL=http://localhost:5000/api/v1
# Timeout des requêtes en secondes
API_TIMEOUT=10
# Clé API pour authentification
API_KEY=your-api-key-here

# ============ CONFIGURATION CAMÉRA ============
# ID du périphérique caméra (0 = caméra par défaut)
CAMERA_ID=0
# Résolution
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
# FPS
CAMERA_FPS=30

# ============ CONFIGURATION AUDIO ============
# Durée d'enregistrement en secondes
AUDIO_DURATION=5
# Fréquence d'échantillonnage
AUDIO_SAMPLE_RATE=44100

# ============ CONFIGURATION UI ============
# Dimensions de la fenêtre
WINDOW_WIDTH=900
WINDOW_HEIGHT=700
# Couleurs (codes couleur hexadécimaux)
THEME_COLOR=#2C3E50
ACCENT_COLOR=#27AE60
ERROR_COLOR=#E74C3C

# ============ TIMEOUTS ET LIMITES ============
# Nombre maximum de tentatives
MAX_ATTEMPTS=3
# Timeout entre tentatives en secondes
ATTEMPT_TIMEOUT=300
# Timeout du scan facial en secondes
FACE_SCAN_TIMEOUT=30
# Timeout du record vocal en secondes
VOICE_RECORD_TIMEOUT=10

# ============ SEUILS BIOMÉTRIQUES ============
# Seuil de confiance reconnaissance faciale (0.0 - 1.0)
FACE_CONFIDENCE_THRESHOLD=0.7
# Seuil de confiance reconnaissance vocale (0.0 - 1.0)
VOICE_CONFIDENCE_THRESHOLD=0.7

# ============ DEBUG ============
# Mode debug (True/False)
DEBUG=False
# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
