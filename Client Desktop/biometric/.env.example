# Configuration Template pour BioAccess-Secure Client Desktop
# Copier vers Client Desktop/.env et adapter les valeurs

# ========== API Configuration ==========
# URL de base de l'API BioAccess-Secure
API_BASE_URL=http://localhost:5000/api/v1

# Timeout pour les requêtes (secondes)
API_TIMEOUT=10

# Vérifier les certificats SSL (true pour production)
VERIFY_SSL=false

# ========== Camera Configuration ==========
# Index de la caméra (0 = caméra par défaut)
# Tester 0, 1, 2, etc si caméra par défaut ne fonctionne pas
CAMERA_INDEX=0

# Résolution caméra
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# FPS cible
CAMERA_FPS=30

# ========== Cache Configuration ==========
# Répertoire pour stocker les encodages en cache
CACHE_DIR=./cache/biometric

# Format encodage (npy = NumPy binary, recommandé)
CACHE_ENCODING_FORMAT=npy

# ========== Logging Configuration ==========
# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Fichier log
LOG_FILE=./logs/biometric.log

# Format log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ========== MUSE Configuration ==========
# Chemin vers les modèles dlib (laisse vide pour chemin par défaut)
MUSE_MODEL_PATH=./biometric/muse/pretrained_model

# Répertoire visages connus (pour mode local seulement)
MUSE_KNOWN_FACES_DIR=./biometric/muse/known_faces

# ========== Security Configuration ==========
# Enable request signing (optionnel, pour future implémentation)
# ENABLE_REQUEST_SIGNING=false

# API Key header (si applicable)
# API_KEY_HEADER=X-API-Key
# API_KEY=your_key_here

# ========== Feature Flags ==========
# Activer cache local
ENABLE_CACHE=true

# Activer offline mode
ENABLE_OFFLINE_MODE=false

# Activer liveness detection
ENABLE_LIVENESS=true

# ========== Performance Configuration ==========
# Nombre max de frames en buffer
FRAME_BUFFER_SIZE=10

# Intervalle traitement (secondes, 0 = chaque frame)
PROCESSING_INTERVAL=0

# Thread count pour traitement (0 = auto)
THREAD_COUNT=0

# ========== Development ==========
# Mode debug
DEBUG_MODE=true

# Verbose output
VERBOSE=false

# Afficher FPS
SHOW_FPS=true
