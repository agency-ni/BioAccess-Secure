# Configuration BioLock Door System
# Copier ce fichier en .env sur le Raspberry Pi

# ============================================================
# BACKEND API
# ============================================================

# URL complète du backend BioAccess-Secure
BACKEND_URL=http://192.168.1.100:5000

# Token d'authentification admin
# À récupérer depuis l'interface admin BioAccess-Secure
ADMIN_TOKEN=CHANGE_ME

# UUID de l'utilisateur pour cette porte
# Creé via POST /admin/users et stocké dans config
USER_ID=uuid-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================================
# HARDWARE GPIO
# ============================================================

# Servo moteur (pour serrure électronique)
SERVO_PIN=18

# Bouton d'activation
BUTTON_PIN=23

# LED verte (système prêt)
LED_GREEN_PIN=24

# LED rouge (erreur/lockout)
LED_RED_PIN=25

# Détecteur mouvement (PIR sensor)
MOTION_SENSOR_PIN=27

# ============================================================
# SERVO & PORTE
# ============================================================

# Angle pour ouverture porte (degrés, 0-180)
OPEN_ANGLE=90

# Angle pour fermeture porte
CLOSED_ANGLE=0

# Durée d'ouverture de la porte (secondes)
OPEN_DURATION=5

# Fréquence PWM du servo (Hz, standard 50)
SERVO_FREQUENCY=50

# ============================================================
# AUTHENTIFICATION BIOMÉTRIQUE
# ============================================================

# Nombre maximum de tentatives avant lockout
MAX_ATTEMPTS=3

# Durée du lockout après MAX_ATTEMPTS échouées (secondes)
COOLDOWN_SEC=60

# Seuil de confiance minimum (0.0-1.0)
# Les deux facteurs (face + voice) doivent être >= ce seuil
CONFIDENCE_THRESHOLD=0.85

# ============================================================
# RÉSEAU
# ============================================================

# Timeout requêtes HTTP (secondes)
REQUEST_TIMEOUT=5

# Nombre de tentatives en cas de timeout réseau
RETRY_COUNT=2

# Délai entre tentatives (secondes)
RETRY_DELAY=1

# ============================================================
# CAPTURE BIOMÉTRIQUE
# ============================================================

# Durée capture faciale (secondes)
FACE_CAPTURE_DURATION=3

# Durée enregistrement vocal (secondes)
VOICE_CAPTURE_DURATION=3

# Index caméra (0 = défaut, 1 = seconde, etc.)
CAMERA_INDEX=0

# Index microphone (-1 = défaut, 0/1/2/... pour microphones spécifiques)
MICROPHONE_INDEX=-1

# Taux d'échantillonnage audio (Hz)
SAMPLE_RATE=16000

# Nombre de canaux audio (1 = mono, 2 = stéréo)
AUDIO_CHANNELS=1

# ============================================================
# LOGGING
# ============================================================

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Répertoire des logs
LOG_DIR=/var/log/biolock-door

# Fichier principal (par défaut: LOG_DIR/biolock-door.log)
# LOG_FILE=/var/log/biolock-door/biolock-door.log
