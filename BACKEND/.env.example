# Environnement
FLASK_ENV=development
FLASK_APP=run.py
FLASK_DEBUG=0
SECRET_KEY=changez-moi-en-production-avec-une-chaine-tres-longue-128-caracteres-minimum-absolument-impossible-a-brute-forcer-1234567890
JWT_SECRET_KEY=changez-moi-aussi-avec-une-autre-chaine-tres-longue-et-totalement-differente-de-la-premiere

# Base de données
DATABASE_URL=postgresql://bioaccess_user:BioAccess2026!@localhost:5432/bioaccess_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_SSL_MODE=require

# Redis
REDIS_URL=redis://:Redis2026!@localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Sécurité
BCRYPT_ROUNDS=12
JWT_ACCESS_TOKEN_EXPIRES=900  # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=2592000  # 30 jours
JWT_ALGORITHM=HS512
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# Rate Limiting
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_LOGIN=5/15minutes
RATE_LIMIT_API=1000/minute
RATE_LIMIT_BIOMETRIC=10/minute

# CORS
CORS_ORIGINS=https://app.bioaccess.com,https://admin.bioaccess.com
CORS_ALLOW_CREDENTIALS=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bioaccess.log
AUDIT_LOG_FILE=logs/audit.log

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=True

# Uploads
MAX_CONTENT_LENGTH=10485760  # 10MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,wav,mp3
UPLOAD_FOLDER=uploads

# API
API_VERSION=v1
API_PREFIX=/api/v1
API_KEY_HEADER=X-API-Key