# Environnement
FLASK_ENV=development
FLASK_APP=run.py
FLASK_DEBUG=1

# Base de données
DATABASE_URL=postgresql://bioaccess_user:BioAccess2026!@localhost/bioaccess_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Sécurité
SECRET_KEY=changez-moi-en-production-avec-une-chaine-tres-longue-et-aleatoire
JWT_SECRET_KEY=changez-moi-aussi-avec-une-autre-chaine-aleatoire
JWT_ACCESS_TOKEN_EXPIRES=3600  # 1 heure
JWT_REFRESH_TOKEN_EXPIRES=2592000  # 30 jours
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_LOGIN=5/15minutes

# CORS
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bioaccess.log

# API
API_VERSION=v1
API_PREFIX=/api/v1