# =====================================================================
# Configuration pour Docker Compose - BioAccess Secure
# =====================================================================
# 
# INSTRUCTIONS:
# 1. Copier ce fichier en .env.docker
# 2. Les variables marquées "REQUIS" doivent être changées
# 3. Lancer: docker-compose --env-file .env.docker up -d
#
# =====================================================================

# ✅ ENVIRONNEMENT
FLASK_ENV=production

# ✅ BASE DE DONNÉES PostgreSQL
POSTGRES_DB=bioaccess_db
POSTGRES_USER=bioaccess_user
# 🔴 REQUIS: Générer une mot de passe sécurisé (32+ caractères, alphanumériques + symboles)
POSTGRES_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_SECURISE_32_CARACTERES_MIN

# ✅ REDIS
# 🔴 REQUIS: Générer une mot de passe sécurisé pour Redis (32+ caractères)
REDIS_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_REDIS_SECURISE

# ✅ SÉCURITÉ - CLÉS SECRÈTES
# 🔴 REQUIS CRITIQUEMENT: Générer avec:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGEZ_MOI_CLE_SECRETE_256_BITS_GENEREE_AVEC_SECRETS_TOKEN_HEX_32

# 🔴 REQUIS CRITIQUEMENT: Différent de SECRET_KEY
#    python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGEZ_MOI_CLE_JWT_DIFFERENTE_256_BITS

# =====================================================================
# OPTIONNEL - Paramètres avancés
# =====================================================================

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bioaccess.log

# Rate Limiting
RATE_LIMIT_LOGIN=5/15minutes
RATE_LIMIT_API=1000/minute

# JWT
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000
JWT_ALGORITHM=HS512

# =====================================================================
# ⚠️ IMPORTANT POUR LA PRODUCTION
# =====================================================================
#
# 1. CHANGE TOUS LES "CHANGEZ_MOI_*" AVANT DE LANCER
#
# 2. Générer des clés sécurisées:
#    
#    Bash/Linux:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
#    
#    PowerShell (Windows):
#    [System.Convert]::ToBase64String((1..32 | % {Get-Random -Max 256}))
#
# 3. Stocker ce fichier de manière sécurisée (pas dans git!)
#
# 4. Utiliser un gestionnaire de secrets en production:
#    - Docker Swarm Secrets
#    - Kubernetes Secrets
#    - HashiCorp Vault
#    - AWS Secrets Manager
#
# =====================================================================
